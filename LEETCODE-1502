class Solution:
    def canMakeArithmeticProgression(self, arr: List[int]) -> bool:
        arr.sort()
        print(arr)
        diff=abs(arr[0]-arr[1])
        print(diff)
        for i in range(1,len(arr)-1):
            if abs(arr[i]-arr[i+1])!=diff:
                return False
        return True
